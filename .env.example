# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-5.6-luna

# inspect-ai evals
INSPECT_EVAL_MODEL=openai/${OPENAI_DEFAULT_MODEL}
INSPECT_GRADER_MODEL=openai/gpt-5.6-luna

# Interactive Brokers (TWS / IB Gateway must be running with API access enabled)
IB_HOST=127.0.0.1
IB_PORT=7497            # 7497/7496 TWS paper/live, 4002/4001 Gateway paper/live
IB_CLIENT_ID=1